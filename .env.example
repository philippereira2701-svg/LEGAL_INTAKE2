# Core Infrastructure
APP_ENV=development
APP_BASE_URL=http://localhost:5000
DATABASE_URL=postgresql://legal_intake:legal_intake@localhost:5432/legal_intake
REDIS_URL=redis://localhost:6379/0

# AI Scoring
GEMINI_API_KEY=your_gemini_api_key_here

# Security / Encryption
JWT_SECRET_KEY=replace_with_secure_random_string
FLASK_SECRET_KEY=replace_with_secure_random_string
PII_ENCRYPTION_KEY=base64_urlsafe_32byte_key
SENTRY_DSN=

# Default Communications Provider (tenant overrides supported in DB)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15555550100
